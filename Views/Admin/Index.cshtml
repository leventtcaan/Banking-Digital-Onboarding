@model IEnumerable<Banking_Digital_Onboarding.Models.CustomerApplication>
@{
    ViewData["Title"] = "Gelen Başvurular";
}

<div class="container mt-5">
    <h2 class="mb-4">Banka Personeli - Başvuru Yönetim Paneli</h2>

    <table class="table table-hover table-striped shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Ad Soyad</th>
                <th>Başvuru Tipi</th>
                <th>İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.FullName</td>
                    <td>@item.ApplicationType</td>
                    <td>
                        <a asp-controller="Admin" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                            Detayları Gör
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>